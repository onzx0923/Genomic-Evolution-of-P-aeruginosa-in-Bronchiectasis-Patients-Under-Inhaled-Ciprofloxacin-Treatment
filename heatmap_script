# Python
import pandas as pd
import glob
import os

# Define folder path
folder = os.path.expanduser("~/Desktop/rgi_results")

# Searches the folder for all files that start with rgi_ & end with .txt
files = glob.glob(os.path.join(folder, "rgi_*.txt"))

data = []

for file in files:
    # Get sample name by looking at just file name with rgi_ and .txt removed
    sample = os.path.basename(file).replace("rgi_", "").replace(".txt", "")
    
    df = pd.read_csv(file, sep="\t")
    
    # Column that contain AMR gene name
    if "Best_Hit_ARO" in df.columns:
     genes = df["Best_Hit_ARO"]
    else:
     print(f"Warning: column not found in {file}")
    
    # dropna() remove missing values, unique() ensures each gene is only counted once per sample
    for gene in genes.dropna().unique():
        data.append([sample, gene])

# Create dataframe with duplicates dropped
df_all = pd.DataFrame(data, columns=["Sample", "Gene"]).drop_duplicates()

# Presence absence matrix (cross tab of rows = genes, columns = samples, values = counts)
matrix = pd.crosstab(df_all["Gene"], df_all["Sample"])

# Save matrix
matrix.to_csv(os.path.join(folder, "matrix.tsv"), sep="\t")

# Core genes (present in all samples including PAO1)
core = matrix[(matrix == 1).all(axis=1)]

# Save core genes
core.to_csv(os.path.join(folder, "core_genes.tsv"), sep="\t")

print("Done")
print("matrix.tsv")
print("core_genes.tsv")


